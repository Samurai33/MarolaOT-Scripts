{
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)",
      "Edit(**/credentials.json)",
      "Edit(**/secrets.json)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(~/.ssh/**)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git clean -xfd *)",
      "Bash(rm -rf *)",
      "PowerShell(Remove-Item * -Recurse * -Force *)",
      "PowerShell(git push --force *)",
      "PowerShell(git reset --hard *)",
      "PowerShell(git clean -fd *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "PowerShell(git push *)",
      "PowerShell(git merge *)",
      "PowerShell(git rebase *)"
    ]
  },
  "autoMemoryEnabled": true
}
